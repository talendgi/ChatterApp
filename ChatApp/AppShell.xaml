<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="ChatApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:ChatApp.Views.Pages"
    >

    <TabBar>
        <ShellContent
            Title="Chat"
            ContentTemplate="{DataTemplate pages:ChatListPage}"
            Route="ChatListPage" />

        <ShellContent
            Title="Status"
            ContentTemplate="{DataTemplate pages:StatusPage}"
            Route="StatusPage" />

        <ShellContent
            Title="Calls"
            ContentTemplate="{DataTemplate pages:CallsPage}"
            Route="CallsPage" />
    </TabBar>

</Shell>
