<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ChatApp.Views.Pages.NewChatPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:ChatApp.ViewModels"
    x:DataType="viewmodels:NewChatViewModel"
    Title="New Chat">

    <Grid Padding="24">
        <VerticalStackLayout Spacing="10" VerticalOptions="Start">
            <Label Text="Start chat by phone number" FontAttributes="Bold" />
            <Entry Placeholder="+1..." Keyboard="Telephone" Text="{Binding PhoneNumber}" />
            <Button Text="Open Chat" Command="{Binding StartChatCommand}" BackgroundColor="#25D366" TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
